          }
        }
      },
      "400": {
        "description": "an error message",
        "schema": {
          "type": "string"
        }
      },
      "default": {
        "description": "a single pet",
        "schema": {
          "$ref": "#/definitions/Pet"
        }
      }
    }
  }
}
